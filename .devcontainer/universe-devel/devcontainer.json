{
  "name": "autoware:universe-devel",
  "dockerComposeFile": "../../docker/devcontainer/universe-devel.compose.yaml",
  "service": "autoware-devel",
  "workspaceFolder": "/home/aw/autoware",
  "containerUser": "root",
  "remoteUser": "aw",
  "overrideCommand": false,
  "initializeCommand": "mkdir -p ${localEnv:HOME}/autoware_data && xhost +local:docker",
  "postCreateCommand": "echo 'source /opt/ros/$ROS_DISTRO/setup.bash' >> ~/.bashrc",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
